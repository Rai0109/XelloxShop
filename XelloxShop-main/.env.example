# =====================================================
#  XELLOX SHOP — Environment Variables
#  Copy file này thành .env và điền giá trị thật
#  Trên Railway: vào Settings → Variables để cấu hình
# =====================================================

# ── BẮT BUỘC ──────────────────────────────────────

# Khoá bí mật Flask (đặt chuỗi random dài, KHÔNG để mặc định)
SECRET_KEY=thay_bang_chuoi_random_cua_ban_it_nhat_32_ky_tu

# ── EMAIL (SMTP) ───────────────────────────────────

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_gmail@gmail.com
# Gmail App Password (không phải mật khẩu đăng nhập)
# Tạo tại: myaccount.google.com/apppasswords
SMTP_PASS=xxxx xxxx xxxx xxxx
SMTP_SENDER=Xellox Shop <your_gmail@gmail.com>

# ── THÔNG TIN SHOP ────────────────────────────────

SHOP_NAME=Xellox Shop
SUPPORT_EMAIL=support@example.com
SUPPORT_PHONE=0900000000
SUPPORT_FB=https://facebook.com/yourpage

# ── CLOUDINARY (lưu ảnh/file - tuỳ chọn) ─────────
# Đăng ký miễn phí tại cloudinary.com
# Nếu không cấu hình, file sẽ lưu local (mất khi Railway redeploy)
CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name

# ── MBBANK (thanh toán tự động - tuỳ chọn) ────────
# Nếu không dùng, bỏ trống (app vẫn chạy bình thường)
MB_USERNAME=
MB_PASSWORD=

# ── GIỚI HẠN FILE UPLOAD ─────────────────────────

MAX_IMAGE_MB=10
MAX_FILE_MB=200

# ── ĐƯỜNG DẪN DỮ LIỆU (Railway tự inject $RAILWAY_VOLUME_MOUNT_PATH) ──
# Nếu dùng Railway Volume, set DATA_DIR và UPLOAD_DIR về volume path
# DATA_DIR=/data
# UPLOAD_DIR=/data/uploads

# ── BẢO MẬT DOWNLOAD LINK ─────────────────────────
# Để trống = tự sinh ngẫu nhiên mỗi lần restart
DOWNLOAD_SECRET=
